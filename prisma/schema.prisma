// Prisma schema for TheLakesGuide.co.uk

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Business {
  id                    String          @id @default(uuid())
  slug                  String          @unique
  name                  String
  categoryId            String
  category              Category        @relation(fields: [categoryId], references: [id])
  address               String
  postcode              String
  lat                   Float?
  lng                   Float?
  phone                 String?
  email                 String?
  website               String?
  description           String?         @db.Text
  shortDescription      String?
  images                String[]        // Array of image URLs
  tags                  String[]        // Searchable tags e.g. ["beach","seafront","dog-friendly"]
  openingHours          Json?
  priceRange            String?         // £, ££, £££, ££££
  listingTier           String          @default("free") // free, standard, featured, premium
  claimed               Boolean         @default(false)
  secondaryCategoryIds  String[]        // Additional category IDs this business appears in
  placeId               String?         // Google Places ID
  rating                Float?          // Google rating 1-5
  reviewCount           Int?            // Number of Google reviews
  hygieneRating         String?         // FSA food hygiene: "5","4","3","2","1","0","AwaitingInspection","Exempt"
  hygieneRatingDate     DateTime?       // Date of last FSA inspection
  hygieneRatingShow     Boolean         @default(true) // owner can hide it after claiming
  fhrsId                String?         // FSA establishment ID — links to ratings.food.gov.uk/business/en-GB/{id}
  userId                String?
  user                  User?           @relation(fields: [userId], references: [id])
  stripeSubscriptionId  String?
  stripeCustomerId      String?
  featured              Boolean         @default(false)
  clicks                BusinessClick[]
  hubTier               String          @default("free") // "free" | "pro"
  weeklyEmailEnabled    Boolean         @default(true)
  googleReviewCachedAt  DateTime?
  boostCredits          Int             @default(0)
  boosts                ListingBoost[]
  reviewSnapshots       ReviewSnapshot[]
  emailLogs             WeeklyEmailLog[]
  claimRequests         ClaimRequest[]
  reviews               Review[]
  outreachLogs          OutreachLog[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([listingTier])
  @@index([claimed])
}

model Review {
  id              String    @id @default(uuid())
  businessId      String
  business        Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  displayName     String?
  email           String
  emailVerifiedAt DateTime?
  emailToken      String?   @unique
  emailTokenExp   DateTime?

  starRating      Int
  title           String?
  body            String    @db.Text

  status          String    @default("unverified") // unverified | pending | approved | rejected
  verifiedType    String    @default("none")        // none | email | purchase
  removalNote     String?
  rejectionReason String?

  receiptImageUrl String?

  ipAddress       String?
  ipHashed        Boolean   @default(false)

  flaggedAt       DateTime?
  flagReason      String?
  flagStatus      String?   // pending | reviewed

  images          ReviewImage[]
  response        ReviewResponse?

  createdAt       DateTime  @default(now())
  approvedAt      DateTime?

  @@index([businessId])
  @@index([status])
  @@index([email])
  @@index([emailToken])
  @@index([ipAddress])
}

model ReviewImage {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([reviewId])
}

model ReviewResponse {
  id         String   @id @default(uuid())
  reviewId   String   @unique
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  businessId String
  body       String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
}

model BusinessClick {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       String   // "website" | "phone" | "directions" | "google_reviews"
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([createdAt])
  @@index([businessId, type])
}

model Category {
  id                String      @id @default(uuid())
  slug              String      @unique
  name              String
  description       String?     @db.Text
  icon              String?
  parentId          String?
  parent            Category?   @relation("CategoryToCategory", fields: [parentId], references: [id])
  children          Category[]  @relation("CategoryToCategory")
  businesses        Business[]
  boosts           ListingBoost[]
  metaTitle         String?
  metaDescription   String?
  sortOrder         Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([slug])
  @@index([parentId])
}

model Area {
  id              String    @id @default(uuid())
  slug            String    @unique
  name            String
  description     String?   @db.Text
  lat             Float?
  lng             Float?
  featuredImage   String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
}

model Event {
  id              String    @id @default(uuid())
  slug            String    @unique
  name            String
  description     String?   @db.Text
  dateStart       DateTime
  dateEnd         DateTime?
  venueId         String?
  venueName       String?
  featuredImage   String?
  category        String?
  featured        Boolean   @default(false)
  metaTitle       String?
  metaDescription String?
  source          String    @default("editorial") // editorial | eventbrite | submission
  externalId      String?   @unique // Eventbrite event ID — prevents duplicates
  status          String    @default("approved") // approved | hidden
  link            String?
  isFree          Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([dateStart])
  @@index([featured])
  @@index([status])
  @@index([externalId])
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique
  emailVerified DateTime?
  password      String
  name          String?
  image         String?
  role          String      @default("user") // user, admin
  businesses    Business[]
  accounts      Account[]
  sessions      Session[]
  blogPosts     BlogPost[]
  claimRequests ClaimRequest[]
  inviteTokens  InviteToken[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([email])
}

model ClaimRequest {
  id         String    @id @default(uuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  email      String
  message    String?   @db.Text
  status     String    @default("pending") // "pending" | "approved" | "rejected"
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime  @default(now())

  @@index([businessId])
  @@index([status])
  @@index([email])
}

model InviteToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Subscription {
  id                  String    @id @default(uuid())
  businessId          String
  tier                String    // standard, featured, premium
  stripeSubscriptionId String   @unique
  stripeCustomerId    String
  status              String    // active, past_due, cancelled, incomplete
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAt            DateTime?
  canceledAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([businessId])
  @@index([stripeSubscriptionId])
  @@index([status])
}

model BlogPost {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  content         String    @db.Text
  excerpt         String?
  featuredImage   String?
  authorId        String
  author          User      @relation(fields: [authorId], references: [id])
  published       Boolean   @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([authorId])
}

model ListingBoost {
  id                    String    @id @default(uuid())
  businessId            String
  business              Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categoryId            String
  category              Category  @relation(fields: [categoryId], references: [id])
  type                  String    // "standard"|"weekend"|"event"|"open2026"
  label                 String?   // public label e.g. "Air Show Weekend"
  startsAt              DateTime
  endsAt                DateTime
  pricePence            Int
  stripePaymentIntentId String?   @unique
  status                String    @default("active") // "active"|"expired"|"cancelled"
  createdAt             DateTime  @default(now())

  @@index([businessId])
  @@index([categoryId])
  @@index([startsAt, endsAt])
  @@index([status])
}

model ReviewSnapshot {
  id          String   @id @default(uuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  rating      Float
  reviewCount Int
  snapshotAt  DateTime @default(now())

  @@index([businessId])
  @@index([snapshotAt])
}

model WeeklyEmailLog {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sentAt     DateTime @default(now())
  weekStart  DateTime

  @@index([businessId])
  @@index([sentAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique @default(uuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}

model PageView {
  id        String   @id @default(uuid())
  path      String
  referrer  String?
  device    String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model OutreachLog {
  id         String   @id @default(uuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       String   // "claim_invite" | "upgrade_nudge" | "boost_upsell"
  sentTo     String
  sentAt     DateTime @default(now())
  sentBy     String?  // admin userId
  note       String?

  @@index([businessId])
  @@index([type])
  @@index([sentAt])
}
